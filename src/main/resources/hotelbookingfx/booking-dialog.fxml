<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<DialogPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hotelbookingfx.controller.BookingDialogController">
    <header>
        <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Создание бронирования" />
    </header>
    <content>
        <VBox spacing="15">
            <TitledPane animated="false" expanded="true" text="Информация о клиенте">
                <GridPane>
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" prefWidth="120" />
                        <ColumnConstraints halignment="LEFT" prefWidth="400" />
                    </columnConstraints>

                    <Label style="-fx-font-weight: bold;" text="Клиент:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <ComboBox onAction="#updateClientInfo" fx:id="clientComboBox" prefWidth="150.0" promptText="Выберите клиента" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label style="-fx-font-weight: bold;" text="ФИО:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <Label style="-fx-font-weight: bold;" fx:id="fio" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <Label style="-fx-font-weight: bold;" text="Телефон:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <Label style="-fx-font-weight: bold;" fx:id="phone" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <Label style="-fx-font-weight: bold;" text="Паспорт:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <Label style="-fx-font-weight: bold;" fx:id="passport" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    <Label style="-fx-font-weight: bold;" text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Label style="-fx-font-weight: bold;" fx:id="email" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                </GridPane>
            </TitledPane>


            <TitledPane animated="false" expanded="true" text="Информация о номере">
                <GridPane>
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" prefWidth="120" />
                        <ColumnConstraints halignment="LEFT" prefWidth="400" />
                    </columnConstraints>

                    <Label style="-fx-font-weight: bold;" text="Номер:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <ComboBox onAction="#updateRoomInfo" fx:id="roomComboBox" prefWidth="150.0" promptText="Выберите номер" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label style="-fx-font-weight: bold;" text="Тип:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <Label style="-fx-font-weight: bold;" fx:id="type" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <Label style="-fx-font-weight: bold;" text="Номер комнаты:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <Label style="-fx-font-weight: bold;" fx:id="roomNumber" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <Label style="-fx-font-weight: bold;" text="Цена:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <Label style="-fx-font-weight: bold;" fx:id="pricePerNight" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    <Label style="-fx-font-weight: bold;" text="Статус:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Label style="-fx-font-weight: bold;" fx:id="status" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    <Label style="-fx-font-weight: bold;" text="Дата заезда" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <DatePicker fx:id="checkInDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                    <Label style="-fx-font-weight: bold;" text="Дата выезда" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                    <DatePicker fx:id="checkOutDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                </GridPane>
            </TitledPane>


        </VBox>
    </content>

    <ButtonType fx:constant="OK" />
    <ButtonType fx:constant="CANCEL" />

</DialogPane>